PORT=3001
FRONTEND_URL=https://lauridsenproduction.vip
JWT_SECRET=change_to_random_string_in_production
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
EMAIL_MODE=production

# ── Admin & site URLs ──────────────────────────────────────────────────────────
ADMIN_EMAIL=your_admin_email@example.com
BASE_URL=https://lauridsenproduction.vip
# ⚠️  KEEP THIS FALSE IN PRODUCTION — only set to true for local dev
DISABLE_RATE_LIMIT=false

# ── Database (PostgreSQL for production, SQLite for local dev) ─────────────────
# Production: set this to your Neon/Supabase connection string
# Local dev:  leave empty (schema.prisma falls back to file:./dev.db for sqlite)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Gmail SMTP (App Password) ──────────────────────────────────────────────────
# How to generate an App Password:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification if not already on
#   3. Search "App Passwords" > select app "Mail" + device "Other" > name it "Studio Site"
#   4. Copy the 16-character password and paste it below (no spaces)
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Lauridsen Production <your_gmail@gmail.com>
